<Window x:Class="UareU.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mask Detection" Height="520" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1e1e1e">

        <!-- Layout columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- CAMERA PREVIEW -->
        <Border Grid.Column="0"
                Margin="15"
                CornerRadius="10"
                Background="Black"
                BorderBrush="#444"
                BorderThickness="2">

            <Image Name="CameraImage"
                   Stretch="Uniform"/>
        </Border>

        <!-- RIGHT PANEL -->
        <StackPanel Grid.Column="1"
                    Margin="20"
                    VerticalAlignment="Center">

            <TextBlock Text="Face Mask Detection"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0 0 0 30"/>

            <!-- RESULT TEXT -->
            <Border Background="#2d2d30"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0 0 0 30">
                <TextBlock Name="ResultText"
                           Text="Waiting for camera..."
                           FontSize="22"
                           Foreground="#00ff9c"
                           TextAlignment="Center"/>
            </Border>

            <!-- BUTTONS -->
            <Button Name="StartBtn"
                    Content="Start Camera"
                    Height="45"
                    Margin="0 0 0 10"
                    Click="StartBtn_Click"/>

            <Button Name="StopBtn"
                    Content="Stop Camera"
                    Height="45"
                    Click="StopBtn_Click"/>

        </StackPanel>

    </Grid>
</Window>