<Page x:Class="WpfApp.Views.DatabasePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DatabasePage">

    <Grid Margin="35">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Margin="0,0,0,25">
            <TextBlock Text="Face Database"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#333"/>

            <TextBlock Text="Manage registered faces"
                       FontSize="16"
                       Foreground="#777"/>
        </StackPanel>

        <!-- MAIN CARD -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="20"
                Padding="25"
                BorderBrush="#E6E6E6"
                BorderThickness="1">

            <DataGrid x:Name="FaceGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      RowHeight="75"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="Transparent">

                <!-- Modern header style -->
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#666"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>

                    <!-- Remove ugly row selection color -->
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border CornerRadius="15"
                                            Background="White"
                                            BorderBrush="#EEEEEE"
                                            BorderThickness="1"
                                            Padding="5">
                                        <DataGridCellsPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>

                    <!-- ID -->
                    <DataGridTextColumn Header="ID"
                                        Width="120"
                                        Binding="{Binding RecordId}"/>

                    <!-- FACE -->
                    <DataGridTemplateColumn Header="Face" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12"
                                        Width="60"
                                        Height="60"
                                        ClipToBounds="True"
                                        BorderBrush="#EEE"
                                        BorderThickness="1">
                                    <Image Source="{Binding FaceImage}"
                                           Stretch="Fill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ACTION -->
                    <DataGridTemplateColumn Header="Action" Width="250">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal">

                                    <!-- EDIT -->
                                    <Button Content="Edit"
                                            Width="90"
                                            Height="38"
                                            Margin="5"
                                            Background="#5C6BC0"
                                            Foreground="White"
                                            Click="Edit_Click"/>

                                    <!-- DELETE -->
                                    <Button Content="Delete"
                                            Width="90"
                                            Height="38"
                                            Margin="5"
                                            Background="#EF5350"
                                            Foreground="White"
                                            Click="Delete_Click"/>

                                </StackPanel>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
