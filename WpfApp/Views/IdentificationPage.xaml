<Page x:Class="WpfApp.Views.IdentificationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="IdentificationPage"
       Loaded="Page_Loaded"
Unloaded="Page_Unloaded"
      >

    <Grid Background="#F5F7FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================================================== -->
        <!-- LEFT SIDE : IDENTIFICATION RESULT -->
        <!-- ===================================================== -->
        <Grid Grid.Column="0" Margin="40">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Face Identification"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="#222"/>

                <TextBlock x:Name="Detail"
                           Text="Camera is scanning for a face..."
                           FontSize="16"
                           Foreground="#777"/>
            </StackPanel>

            <Border Grid.Row="1"
        CornerRadius="30"
        BorderBrush="#E5E5E5"
        BorderThickness="1"
        Padding="20">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F4F8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
                </Border.Effect>

                <Grid>

                    <!-- FACE IMAGE -->
                    <Border CornerRadius="20"
                Background="#EEF2F7"
                ClipToBounds="True">

                        <Image x:Name="captureImage"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>


                    <!-- ===================================== -->
                    <!-- MATCH BADGE (TOP RIGHT) -->
                    <!-- ===================================== -->
                    <Border x:Name="PreviewBadge"
                Width="70"
                Height="70"
                CornerRadius="35"
                Background="#4CAF50"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20">

                        <TextBlock x:Name="PreviewBadgeIcon"
                       Text="✔"
                       FontSize="32"
                       Foreground="White"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
                    </Border>


                    <!-- ===================================== -->
                    <!-- GLASS INFO PANEL (BOTTOM OVERLAY) -->
                    <!-- ===================================== -->
                    <Border VerticalAlignment="Bottom"
                Height="90"
                CornerRadius="0,0,20,20"
                Padding="20">

                        <Border.Background>
                            <!-- glass effect -->
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                <GradientStop Color="#E6FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- NAME -->
                            <StackPanel>
                                <TextBlock Text="IDENTIFIED PERSON"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#666"/>

                                <TextBlock x:Name="PreviewPersonName"
                               Text="Waiting for match..."
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111"/>
                            </StackPanel>

                            <!-- SCORE -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="MATCH"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#666"
                               HorizontalAlignment="Right"/>

                                <TextBlock x:Name="PreviewScore"
                               Text="-- %"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1E88E5"
                               HorizontalAlignment="Right"/>
                            </StackPanel>

                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- MATCH RESULT PANEL -->
            <Border Grid.Row="2"
                    x:Name="MatchPanel"
                    Margin="0,25,0,0"
                    Padding="18"
                    CornerRadius="18"
                    Background="#EEF4FF"
                    BorderBrush="#D6E4FF"
                    BorderThickness="1">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ICON -->
                    <Border x:Name="MatchIconBg"
                            Width="44"
                            Height="44"
                            CornerRadius="12"
                            Background="#4A90E2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                        <TextBlock x:Name="MatchIcon"
                                   Text="📷"
                                   FontSize="22"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- TEXT -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock x:Name="MatchTitle"
                                   Text="Waiting for face..."
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="#1A1A1A"/>

                        <TextBlock x:Name="MatchScoreText"
                                   Text="No match yet"
                                   FontSize="14"
                                   Foreground="#666"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- ===================================================== -->
        <!-- RIGHT SIDE : CAMERA (SAME AS BEFORE) -->
        <!-- ===================================================== -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="20"
                Padding="20"
                Margin="30"
                BorderBrush="#E6E6E6"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📷 Live Camera"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>

                <Border Grid.Row="1"
                        CornerRadius="15"
                        Background="#111"
                        ClipToBounds="True">

                    <Grid>
                        <Image x:Name="liveStreamImage" Stretch="Uniform"/>

                        <Canvas x:Name="canvasOverlay"
                                IsHitTestVisible="False"
                                Width="{Binding ElementName=liveStreamImage, Path=ActualWidth}"
                                Height="{Binding ElementName=liveStreamImage, Path=ActualHeight}"/>

                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="15"
                                Padding="8,4"
                                CornerRadius="8"
                                Background="#66000000">
                            <TextBlock Text="LIVE"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                        </Border>

                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="15"
                                Padding="8,4"
                                CornerRadius="8"
                                Background="#66000000">

                            <TextBlock x:Name="FpsText"
                                       Text="0 FPS"
                                       Foreground="#00FF90"
                                       FontWeight="Bold"
                                       FontSize="14"/>
                        </Border>

                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Page>
