<Window x:Class="UareU.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UareU.Views"
        mc:Ignorable="d"
        Title="MainWindow" WindowStartupLocation="Manual" SizeToContent="Manual">
    <Grid Background="#F5F6FA">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
            <!-- Camera Zone -->
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT SIDEBAR ========== -->
        <Border Background="#474E93">
            <StackPanel Margin="20">

                <TextBlock Text="HID UareU"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="10,20,10,30"/>

                <Button Content="📷 Auto Capture"
                    Style="{DynamicResource  FancyButton}"
                    Margin="0,10"
                    Click="AutoCapture"/>

                <Button Content="🙂 Image Match"
                    Style="{DynamicResource  FancyButton}"
                    Margin="0,10"
                    Click="Matching"/>

                <Button Content="🙂 Verification"
                    Style="{DynamicResource  FancyButton}"
                    Margin="0,10"
                    Click="Verification"/>

                <Button Content="💾 Enrollment"
                    Style="{DynamicResource  FancyButton}"
                    Margin="0,10"
                    Click="Enrollment"/>

                <Button Content="🔎 Identification"
                    Style="{DynamicResource  FancyButton}"
                    Margin="0,10"
                    Click="Authentication"/>


                <Button Content="☁ Database"
                     Style="{DynamicResource  FancyButton}"
                     Margin="0,10"
                     Click="Database"/>


            </StackPanel>
        </Border>
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               Grid.ColumnSpan="2"
               NavigationUIVisibility="Hidden"
               
               />

    </Grid>
</Window>
